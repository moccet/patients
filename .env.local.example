# Patient portal env vars. Copy to .env.local and fill in.
#
# Both NEXT_PUBLIC_* values are inlined at build time; rebuild after change.

# Supabase project. SAME values as the thewellness/ main app so sessions
# work across both origins.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Base URL of the main app that serves /api/v1/me/*.
# Dev:        http://localhost:3000
# Production: https://www.thewellnesslondon.com
NEXT_PUBLIC_API_BASE=http://localhost:3000
